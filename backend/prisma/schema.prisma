generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nombre    String
  empresaId Int
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  telefono  String?
  email     String?
  direccion String?
  ordenes   OrdenTrabajo[]
  ventas    Venta[]
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  direccion String?
  telefono  String?
  email     String?
  clientes  Cliente[]
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  stock     Int      @default(0)
  unidad    String
  bajoStock Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Maquina {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  disponible  Boolean  @default(true)
  asignaciones AsignacionMaquina[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrdenTrabajo {
  id          Int      @id @default(autoincrement())
  numeroOrden String   @unique
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  pieza       String
  cantidad    Int
  fechaInicio DateTime @default(now())
  fechaEntrega DateTime?
  estado      String   @default("Pendiente")
  materialesRequeridos String?
  maquinas    AsignacionMaquina[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AsignacionMaquina {
  id         Int      @id @default(autoincrement())
  ordenId    Int
  maquinaId  Int
  orden      OrdenTrabajo @relation(fields: [ordenId], references: [id])
  maquina    Maquina      @relation(fields: [maquinaId], references: [id])
  horasUso   Float?
  createdAt  DateTime @default(now())
}

model Venta {
  id          Int      @id @default(autoincrement())
  numeroOrden String   @unique
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  cantidadPiezas Int
  moneda      String
  montoTotal  Float
  iva         Float
  totalConIva Float
  fechaCreacion DateTime @default(now())
  fechaEntrega DateTime
  facturacion String  @default("No facturado")
  pago        String  @default("Pendiente")
  avisoFacturar Boolean @default(true)
  estado      String  @default("Activa")
  pdfUrl      String?   // ← NUEVO CAMPO PARA PDF
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  facturas    Factura[]
}

model Factura {
  id               Int      @id @default(autoincrement())
  ventaId          Int
  venta            Venta    @relation(fields: [ventaId], references: [id])
  numeroFactura    String   @unique
  monto            Float
  fecha            DateTime @default(now())
  cancelada        Boolean  @default(false)
  motivoCancelacion String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  pago             Pago?
}

model Pago {
  id          Int      @id @default(autoincrement())
  facturaId   Int      @unique
  factura     Factura  @relation(fields: [facturaId], references: [id])
  fecha       DateTime @default(now())
  medio       String
  seguimiento String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String?
  rol       String   @default("usuario")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseRequest {
  id                    Int      @id @default(autoincrement())
  solicitante           String
  proyecto              String
  material              String
  dibujo                String?
  ancho                 Float?
  largo                 Float?
  grosor                Float?
  diametro              Float?
  fechaRequerida        DateTime
  descripcion           String?
  numeroPiezas          Int
  directriz             String   @default("esperar")
  proveedor1            String?
  proveedor2            String?
  proveedor3            String?
  proveedorElegido      String?
  dimensionesCotizadas  String?
  propuestaAlternativa  String?
  tiempoEntrega         String?
  fechaCompra           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}